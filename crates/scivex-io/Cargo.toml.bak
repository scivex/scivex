[package]
name = "scivex-io"
version.workspace = true
edition.workspace = true
license.workspace = true
repository.workspace = true
description = "Scivex — CSV, JSON, SQL, Parquet, and Arrow I/O for DataFrames"

[lints]
workspace = true

[dependencies]
scivex-core = { path = "../scivex-core" }
scivex-frame = { path = "../scivex-frame" }
serde_json = { version = "1", optional = true }

# SQL backends
rusqlite = { version = "0.31", optional = true, features = ["bundled"] }
postgres = { version = "0.19", optional = true }
mysql = { version = "25", optional = true }
tiberius = { version = "0.12", optional = true, default-features = false, features = ["rustls"] }
tokio = { version = "1", optional = true, features = ["rt", "net", "io-util"] }
tokio-util = { version = "0.7", optional = true, features = ["compat"] }

# DuckDB
duckdb = { version = "1", optional = true, features = ["bundled"] }

# Parquet & Arrow
parquet_crate = { package = "parquet", version = "55", optional = true, default-features = false, features = ["arrow", "snap", "zstd", "lz4"] }
arrow_crate = { package = "arrow", version = "55", optional = true, default-features = false, features = ["ipc"] }
bytes = { version = "1", optional = true }
serde = { version = "1", features = ["derive"], optional = true }

# Memory-mapped I/O
memmap2 = { version = "0.9", optional = true }

# Excel
calamine = { version = "0.26", optional = true }
rust_xlsxwriter = { version = "0.82", optional = true }

[features]
serde-support = ["dep:serde", "scivex-core/serde-support", "scivex-frame/serde-support"]
default = ["csv"]
csv = []
npy = []
hdf5 = []
json = ["dep:serde_json"]
sqlite = ["dep:rusqlite"]
postgres = ["dep:postgres"]
mysql = ["dep:mysql"]
mssql = ["dep:tiberius", "dep:tokio", "dep:tokio-util"]
duckdb = ["dep:duckdb"]
sql = ["sqlite", "postgres", "mysql", "mssql"]
parquet = ["dep:parquet_crate", "dep:arrow_crate", "dep:bytes"]
arrow = ["dep:arrow_crate"]
avro = []
mmap = ["dep:memmap2"]
excel = ["dep:calamine", "dep:rust_xlsxwriter"]
full = ["csv", "json", "sql", "parquet", "arrow", "npy", "mmap", "excel", "duckdb", "avro", "hdf5"]
